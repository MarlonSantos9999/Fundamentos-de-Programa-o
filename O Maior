#include <stdio.h>
#include <math.h>

int main() {
    int a, b, c, maiorAB, maior;

    scanf("%d %d %d", &a, &b, &c);

    // Maior entre a e b
    maiorAB = (a + b + abs(a - b)) / 2;

    // Maior entre (maiorAB) e c
    maior = (maiorAB + c + abs(maiorAB - c)) / 2;

    printf("%d eh o maior\n", maior);

    return 0;
}
